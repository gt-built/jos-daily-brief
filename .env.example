BRAINJOS_API_URL=https://brainjos.nl/api/daily-brief
BRAINJOS_API_TOKEN=

DAILY_BRIEF_LOCATION=Drunen
DAILY_BRIEF_LATITUDE=51.6861
DAILY_BRIEF_LONGITUDE=5.1314
# Optioneel: extra RSS/Atom-feeds als achtergrond. De NIEUWS-sectie zelf
# gebruikt standaard GDELT (geen sleutel nodig), zie daily_brief/news.py.
DAILY_BRIEF_RSS_FEEDS=NOS|https://feeds.nos.nl/nosnieuwsalgemeen;Tweakers|https://feeds.feedburner.com/tweakers/mixed

# Reddit-variant van de NIEUWS-sectie (daily_brief/reddit_news.py) staat uit
# sinds Reddit's Responsible Builder Policy app-registratie blokkeert.
# DAILY_BRIEF_REDDIT_SUBREDDITS=AI_Agents;ClaudeAI;technology
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=common

OPENAI_API_KEY=
OPENAI_NEWS_MODEL=gpt-5.4-mini

# Vakantiepauze: als beide data gezet zijn, slaat --print stil over binnen
# dit bereik (incl. beide grensdata). --text blijft altijd werken.
# DAILY_BRIEF_PAUSE_FROM=2026-07-19
# DAILY_BRIEF_PAUSE_UNTIL=2026-08-08
